RewriteEngine On


# FORCE HTTPS + NON-WWW (CANONICAL URL)

# Redirect HTTP OR WWW to HTTPS non-www
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.srishankaracancerhospital\.org$ [NC]
RewriteRule ^ https://srishankaracancerhospital.org%{REQUEST_URI} [R=301,L]


# REMOVE SLASH

RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ https://srishankaracancerhospital.org/$1 [R=301,L]


# REMOVE .HTML FROM URL (SEO CLEAN URL)

RewriteCond %{THE_REQUEST} \s/([^.]+)\.html [NC]
RewriteRule ^ /%1 [R=301,L]


# INTERNALLY MAP CLEAN URL → .HTML FILE

RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]


# BLOCK DIRECTORY LISTING

Options -Indexes


# ERROR PAGE

ErrorDocument 404 /404.html

